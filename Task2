<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Client Lead Management</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap');

body {
    font-family:'DM Sans', sans-serif;
    margin:0;
    background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
    color: #d1c4e9;
}

h1 {
    text-align:center;
    margin:20px 0;
    font-size:2.8em;
    background: linear-gradient(90deg,#8e2de2,#4a00e0);
    -webkit-background-clip: text;
    color: transparent;
}

#dashboard { padding:20px; max-width:1200px; margin:auto; }

.top-cards { display:flex; gap:20px; flex-wrap:wrap; margin-bottom:30px; }
.card { flex:1 1 30%; background: #1b1b3a; padding:25px; border-radius:15px; box-shadow:0 5px 20px rgba(0,0,0,0.5); text-align:center; }
.card h3 { margin:0; font-size:1.3em; color:#ba68c8; }
.card p { margin:10px 0 0 0; font-size:1.8em; color:#ce93d8; }

.controls { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:25px; align-items:center; }
.controls input, .controls select { padding:12px; border-radius:8px; border:none; color:#333; font-weight:bold; }
.controls button { padding:12px 18px; cursor:pointer; border:none; border-radius:8px; background: linear-gradient(90deg,#8e2de2,#4a00e0); color:white; font-weight:bold; transition:0.3s; }
.controls button:hover { transform:scale(1.05); }

#leadsTable { width:100%; border-collapse:collapse; border-radius:12px; overflow:hidden; box-shadow:0 5px 20px rgba(0,0,0,0.5); }
#leadsTable th, #leadsTable td { padding:14px; text-align:left; }
#leadsTable th { background: linear-gradient(90deg,#8e2de2,#4a00e0); color:white; }
#leadsTable td { background:#1b1b3a; color:#d1c4e9; }

.status-New { color:white; background:#8e24aa; padding:5px 8px; border-radius:6px; font-weight:bold; }
.status-Contacted { color:white; background:#ab47bc; padding:5px 8px; border-radius:6px; font-weight:bold; }
.status-Converted { color:white; background:#7e57c2; padding:5px 8px; border-radius:6px; font-weight:bold; }

td select { color:#333; font-weight:bold; padding:5px; border-radius:5px; border:none; }
</style>
</head>
<body>

<div id="dashboard">
  <h1>Client Lead Management</h1>

  <div class="top-cards">
    <div class="card"> <h3>Total Leads</h3> <p id="totalLeads">0</p> </div>
    <div class="card"> <h3>Contacted Leads</h3> <p id="contactedLeads">0</p> </div>
    <div class="card"> <h3>Converted Leads</h3> <p id="convertedLeads">0</p> </div>
  </div>

  <div class="controls">
    <input type="text" id="leadName" placeholder="Name">
    <input type="email" id="leadEmail" placeholder="Email">
    <input type="text" id="leadPhone" placeholder="Phone Number">
    <input type="text" id="leadSource" placeholder="Source (Website, Referral...)">
    <button onclick="addLead()">Add Lead</button>
    <input type="text" id="searchInput" placeholder="Search by name/email/phone/source" onkeyup="renderLeads()">
  </div>

  <table id="leadsTable">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Source</th>
        <th>Status</th>
        <th>Added On</th>
      </tr>
    </thead>
    <tbody id="leadsBody"></tbody>
  </table>
</div>

<script>
// Fresh sample leads
let leads = [
  {name:"Sophia Patel", email:"sophia.patel@example.com", phone:"9876543210", source:"Website", status:"New", timestamp:Date.now()-3600000},
  {name:"Liam Kumar", email:"liam.kumar@example.com", phone:"9123456780", source:"Referral", status:"Contacted", timestamp:Date.now()-7200000},
  {name:"Olivia Reddy", email:"olivia.reddy@example.com", phone:"9012345678", source:"Social Media", status:"Converted", timestamp:Date.now()-10800000},
  {name:"Noah Singh", email:"noah.singh@example.com", phone:"9988776655", source:"Website", status:"New", timestamp:Date.now()-5400000},
  {name:"Emma Sharma", email:"emma.sharma@example.com", phone:"9871234560", source:"Referral", status:"Contacted", timestamp:Date.now()-3000000},
  {name:"Aarav Mehta", email:"aarav.mehta@example.com", phone:"9129876543", source:"Website", status:"New", timestamp:Date.now()-6000000},
  {name:"Mia Das", email:"mia.das@example.com", phone:"9018765432", source:"Social Media", status:"Converted", timestamp:Date.now()-2500000},
  {name:"Arjun Rao", email:"arjun.rao@example.com", phone:"9898765432", source:"Website", status:"New", timestamp:Date.now()-1200000}
];

// Save to localStorage for persistence
localStorage.setItem('leads', JSON.stringify(leads));

function saveLeads() { localStorage.setItem('leads', JSON.stringify(leads)); }

function updateAnalytics() {
  document.getElementById('totalLeads').innerText = leads.length;
  document.getElementById('contactedLeads').innerText = leads.filter(l=>l.status==='Contacted').length;
  document.getElementById('convertedLeads').innerText = leads.filter(l=>l.status==='Converted').length;
}

function renderLeads() {
  const tbody = document.getElementById('leadsBody');
  tbody.innerHTML='';
  const search = document.getElementById('searchInput').value.toLowerCase();
  leads.forEach((lead,index)=>{
    if(
      lead.name.toLowerCase().includes(search) ||
      lead.email.toLowerCase().includes(search) ||
      lead.phone.toLowerCase().includes(search) ||
      lead.source.toLowerCase().includes(search)
    ){
      const tr=document.createElement('tr');
      tr.innerHTML=`
        <td>${lead.name}</td>
        <td>${lead.email}</td>
        <td>${lead.phone}</td>
        <td>${lead.source}</td>
        <td>
          <select onchange="updateStatus(${index}, this.value)" class="status-${lead.status}">
            <option ${lead.status==='New'?'selected':''}>New</option>
            <option ${lead.status==='Contacted'?'selected':''}>Contacted</option>
            <option ${lead.status==='Converted'?'selected':''}>Converted</option>
          </select>
        </td>
        <td>${new Date(lead.timestamp).toLocaleString()}</td>
      `;
      tbody.appendChild(tr);
    }
  });
  updateAnalytics();
}

function addLead() {
  const name = document.getElementById('leadName').value.trim();
  const email = document.getElementById('leadEmail').value.trim();
  const phone = document.getElementById('leadPhone').value.trim();
  const source = document.getElementById('leadSource').value.trim();
  if(!name || !email){ alert("Enter name and email"); return; }
  leads.unshift({name,email,phone,source,status:'New',timestamp:Date.now()});
  saveLeads(); renderLeads();
  document.getElementById('leadName').value='';
  document.getElementById('leadEmail').value='';
  document.getElementById('leadPhone').value='';
  document.getElementById('leadSource').value='';
}

function updateStatus(index,status){ leads[index].status=status; saveLeads(); renderLeads(); }

// Render on page load
renderLeads();
</script>

</body>
</html>
